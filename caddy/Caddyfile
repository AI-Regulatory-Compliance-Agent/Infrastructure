# ── Caddy Reverse Proxy — ComplianceAI ───────────────────────
# Routes:
#   /api/*  → FastAPI backend (prefix stripped, so /api/health → /health)
#   /*      → nginx static frontend
#
# TLS: Caddy obtains and renews a free Let's Encrypt certificate for
# the domain automatically (HTTP-01 challenge over port 80).
#
# HTTPS confirmed working 2026-07-08 (NSG port 443 open, Let's
# Encrypt cert issued) — all plain-HTTP traffic now permanently
# redirects to the HTTPS domain.

(site) {
	handle_path /api/* {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:80
	}
}

https://complianceai.centralindia.cloudapp.azure.com {
	import site
}

http://complianceai.centralindia.cloudapp.azure.com, http://20.244.40.144 {
	redir https://complianceai.centralindia.cloudapp.azure.com{uri} permanent
}
